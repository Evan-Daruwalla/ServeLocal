# ServeLocal configuration. Copy to .env and fill in. NEVER commit the real .env.
# In production the app refuses to start if JWT_SECRET is left at its default.

# Secret used to sign auth tokens AND calendar-feed HMACs. 48+ random bytes.
# Generate:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Rotating this invalidates all sessions and calendar subscriptions.
JWT_SECRET=

# Auth token lifetime in hours (default 168 = 7 days). Lower = tighter sessions.
TOKEN_TTL_HOURS=168

# Admin login email (default admin@servelocal.org).
ADMIN_EMAIL=admin@servelocal.org

# Admin login password for the seeded admin account. REQUIRED in production —
# the app refuses to start if left at the built-in default (it's public in source).
ADMIN_PASSWORD=

# Transactional email (Resend). Leave blank to disable email sending — guardian
# consent emails fall back to a console log of the link so local dev still works.
RESEND_API_KEY=

# Guardian consent (students under 18 — see docs/guardian-consent-spec.md).
# Base URL used to build the consent links sent in guardian emails.
PUBLIC_BASE_URL=http://localhost:3000
# Hours a one-time guardian approval link stays valid before it must be resent.
CONSENT_TOKEN_TTL_HOURS=72

# Set to "production" in prod. Enables HSTS and the default-secret guard.
NODE_ENV=development

# CORS: comma-separated exact origins allowed to call the API. Empty = permissive
# "*" (fine for dev / same-origin). Set this in production to lock down CORS.
# ALLOWED_ORIGINS=https://servelocal.org,https://www.servelocal.org

# scrypt cost (N, a power of two). Default 32768 (2^15). Raise in prod for more
# resistance to offline cracking if login latency budget allows (e.g. 65536).
# SCRYPT_N=32768

# Per-IP rate-limit tuning (token-bucket). Defaults shown.
# RL_WRITE_CAP=40
# RL_WRITE_REFILL=1
# RL_READ_CAP=120
# RL_READ_REFILL=2

# Optional: serve HTTPS directly (otherwise TLS is terminated at the proxy).
# Point these at PEM files; rotate by replacing the files and restarting.
# SSL_CERT=/etc/ssl/servelocal/fullchain.pem
# SSL_KEY=/etc/ssl/servelocal/privkey.pem

# Optional overrides (used by tests/scripts; leave unset in normal runs).
# PORT=3000
# DB_FILE=
# BACKUP_DIR=
